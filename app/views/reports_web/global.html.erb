<%= link_to "← Dashboard", root_path %>

<h1>Global Report</h1>

<% if @reports.any? %>
  <table>
    <thead>
      <tr>
        <th>Firm</th>
        <th>Clients With Summaries</th>
      </tr>
    </thead>
    <tbody>
      <% @reports.each do |report| %>
        <tr>
          <td><%= report[:firm_name] %></td>
          <td><%= report[:total_clients_with_summaries] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">No reports available.</p>
<% end %>
